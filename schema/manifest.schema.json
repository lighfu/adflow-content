{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lighfu.github.io/adflow-content/schema/manifest.schema.json",
  "title": "AdFlow Manifest",
  "type": "object",
  "required": ["schemaVersion", "slots", "ads"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "slots": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["strategy", "adIds"],
        "properties": {
          "strategy": { "type": "string", "enum": ["single", "rotate", "weighted"] },
          "adIds": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "ads": {
      "type": "object",
      "additionalProperties": { "$ref": "ad.schema.json" }
    }
  }
}
